{
  "name": "@kystverket/styrbord",
  "version": "1.3.37",
  "description": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kystverket/styrbord.git"
  },
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "style": "./dist/style.css",
      "import": "./dist/style.js"
    },
    "./*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "main": "./dist/style.js",
  "typings": "./dist/src/main.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test": "echo \"Warning: no test specified\" && exit 0",
    "build:css": "sass src/css/index.scss dist/index.css --style=compressed",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "pretty:check": "npx prettier . --check",
    "pretty:fix": "npx prettier . --write",
    "lint:check": "npx eslint .",
    "lint:fix": "npx eslint --fix ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@digdir/designsystemet-css": "~1.9.0",
    "@digdir/designsystemet-react": "~1.9.0",
    "@material-symbols/font-400": "^0.39.0",
    "date-fns": "^4.1.0",
    "exifr": "^7.1.3",
    "react-datepicker": "^8.4.0",
    "react-dom": "^19.0.0",
    "react": "^19.0.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {}
}
