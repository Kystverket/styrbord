{
  "name": "styrbord-root",
  "workspaces": [
    "base",
    "kart"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --parallel --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "storybook:base": "npm run storybook --workspace base",
    "storybook:build": "npm run storybook:build --workspaces --if-present",
    "pretty:check": "npm run pretty:check --workspaces --if-present",
    "pretty:fix": "npm run pretty:fix --workspaces --if-present",
    "lint:check": "npm run lint:check --workspaces --if-present",
    "lint:fix": "npm run lint:fix --workspaces --if-present"
  },
  "dependencies": {},
  "devDependencies": {},
  "version": ""
}
