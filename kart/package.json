{
  "name": "@kystverket/styrbord-kart",
  "version": "0.0.3",
  "description": "",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Kystverket/styrbord.git"
  },
  "exports": {
    ".": {
      "types": "./dist/src/main.d.ts",
      "style": "./dist/style.css",
      "import": "./dist/main.js"
    },
    "./*.css": {
      "import": "./dist/*.css",
      "require": "./dist/*.css"
    }
  },
  "main": "./dist/main.js",
  "typings": "./dist/src/main.d.ts",
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "build": "tsc && vite build",
    "test": "echo \"Warning: no test specified\" && exit 0",
    "build:css": "sass src/css/index.scss dist/index.css --style=compressed",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "pretty:check": "npx prettier . --check",
    "pretty:fix": "npx prettier . --write",
    "lint:check": "npx eslint .",
    "lint:fix": "npx eslint --fix ."
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@kystverket/styrbord": "^1.3.34",
    "terra-draw": "^1.25.0",
    "terra-draw-maplibre-gl-adapter": "^1.3.0",
    "uuid": "^9.0.0"
  },
  "peerDependencies": {
    "geojson": "^0.5.0",
    "maplibre-gl": ">=4.0.0",
    "terra-draw": ">=1.0.0",
    "terra-draw-maplibre-gl-adapter": ">=1.0.0"
  },
  "devDependencies": {
    "maplibre-gl": "^5.0.0"
  }
}
